# The fal.ai key still uses BYOK (Bring Your Own Key): the user enters it in
# the UI and it's stored in browser localStorage. The key never leaves the
# user's browser.
#
# Get your fal.ai key at: https://fal.ai/dashboard/keys

# Brevo transactional email API key, used only by /api/send-email.
BREVO_API_KEY=

# Sender configured and verified in Brevo.
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=BNA Campo Argentino

# Optional: numeric IDs of Brevo transactional templates, one per media type.
# When the matching one is set, the email subject and body are rendered from
# that template. Each template receives these params:
#   params.mediaType  -> "image" | "video"
#   params.mediaLabel -> "imagen" | "video"
#   params.mediaUrl   -> absolute URL of the media (bind to image src / video
#                        poster and to the download button href)
# Leave empty to send the built-in inline HTML instead.
BREVO_TEMPLATE_ID_IMAGE=
BREVO_TEMPLATE_ID_VIDEO=

# Public origin of the deployed app (no trailing slash), e.g.
# https://juegos.tucliente.com. Used to build params.downloadUrl, which points
# the email's download button at the app's /descargar page so the file is saved
# to the device instead of opening in the browser. In local dev, something like
# http://localhost:5173.
PUBLIC_BASE_URL=
